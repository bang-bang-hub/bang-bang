# Copy this file to .env.local (for local dev) and set values there.
# On Azure SWA (or any static host) set these in the platform's env config.

# ─────────────────────────────────────────────────────────────────
# WhatsApp CTA channels
# ─────────────────────────────────────────────────────────────────
# Phone numbers in international format without + or spaces.
# Used by the Header, Hero, RevendaSection, CTASection, Footer, and
# the WishlistForm (city request). Leave blank to fall back to "#contato".
#
NEXT_PUBLIC_WA_REVENDA=
NEXT_PUBLIC_WA_DISTRIBUIDOR=
NEXT_PUBLIC_WA_EVENTOS=

# Optional: full wa.me or custom links that override the numbers above.
# Example: https://wa.me/5531999999999?text=Ol%C3%A1%21
NEXT_PUBLIC_LINK_REVENDA=
NEXT_PUBLIC_LINK_DISTRIBUIDOR=
NEXT_PUBLIC_LINK_EVENTOS=
